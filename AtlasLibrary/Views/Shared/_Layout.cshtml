@{
    var token = Context.Session.GetString("JwtToken");
    var role = Context.Session.GetString("UserRole");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AtlasLibrary</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/AdminPanel.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/UserProfile.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Loan.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AtlasLibrary.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="page-wrapper">
        <header>
            <link rel="stylesheet"
                  href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
            <nav class="navbar navbar-expand-sm navbar-light mb-4">
                <div class="container-fluid px-4">
                    <a class="navbar-brand" asp-controller="Home" asp-action="Index">AtlasLibrary</a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between align-items-center">
                        <ul class="navbar-nav mx-auto nav-pill-wrapper">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Items" asp-action="Index">Items</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="About">About</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Return" asp-action="Index">Återlämning</a>
                            </li>
                        </ul>

                        <div class="d-flex gap-2">
                            <a asp-controller="Cart" asp-action="Index" class="cart-link">
                                <i class="fa-solid fa-cart-arrow-down"></i>
                            </a>
                       
                        </div>

                        <div class="d-flex gap-2">
                            @if (string.IsNullOrEmpty(token))
                            {
                                <a class="btn login-btn" asp-controller="Account" asp-action="Login">Logga in</a>
                            }
                            else
                            {
                                <a class="btn btn-light profile-btn" asp-controller="Profile" asp-action="Index">Profil</a>
                                <a class="btn login-btn" asp-controller="Account" asp-action="Logout">Logga ut</a>
                            }
                        </div>

                    </div>
                </div>
            </nav>
        </header>

        <main role="main" class="container pb-3 main-content">
            @RenderBody()
        </main>

        <footer class="footer-custom">
            <div class="footer-content">
                <div class="footer-section">
                    <h5>AtlasLibrary</h5>
                    <p>Låna böcker och utrustning enkelt och smidigt.</p>
                </div>

                <div class="footer-section">
                    <h5>Kontakt</h5>
                    <p>Telefon: 031-123 45 67</p>
                    <p>E-post: info@atlaslibrary.se</p>
                </div>

                <div class="footer-section">
                    <h5>Öppettider</h5>
                    <p>Mån–Fre: 08:00–17:00</p>
                    <p>Lör &amp; Sön: Stängt</p>
                </div>

                <div class="footer-section">
                    <h5>Länkar</h5>
                    <p><a asp-controller="Home" asp-action="About">About</a></p>
                    <p><a asp-controller="Home" asp-action="Privacy">Privacy</a></p>
                </div>
            </div>

            <div class="footer-bottom">
                &copy; 2026 - AtlasLibrary
            </div>
        </footer>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - AtlasLibrary - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>