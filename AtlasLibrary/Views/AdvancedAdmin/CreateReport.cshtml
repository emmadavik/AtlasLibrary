@model AtlasLibrary.Controllers.AdvancedAdminController.CreateReportViewModel

@{
    ViewData["Title"] = "Skapa rapport";
}

<div class="page-wrapper">
    <div class="top-navigation" style="margin-bottom: 22px;">
        <a asp-controller="AdvancedAdmin" asp-action="Index" class="top-action-btn profile-btn text-decoration-none">
            ← Tillbaka till adminpanelen
        </a>
    </div>

    <div class="form-card">
        <h1>Skapa ny rapport</h1>
        <p class="sub-text">Välj ett eller flera färdiga objekt.</p>

        @if (ViewBag.Error != null)
        {
            <div class="warning-box">
                @ViewBag.Error
            </div>
        }

        <form asp-action="CreateReport" method="post" class="simple-form">
            <div asp-validation-summary="ModelOnly" class="validation-text"></div>

            <div class="form-group">
                <label asp-for="Title">Rapportnamn</label>
                <input asp-for="Title" class="form-input" />
                <span asp-validation-for="Title" class="validation-text"></span>
            </div>

            <div class="form-group">
                <label asp-for="SelectedObjectIds">Välj färdiga objekt</label>

                @if (Model.CompletedObjects != null && Model.CompletedObjects.Any())
                {
                    <div class="checkbox-list">
                        @foreach (var item in Model.CompletedObjects)
                        {
                            <label class="checkbox-item">
                                <input type="checkbox"
                                       name="SelectedObjectIds"
                                       value="@item.Id"
                                @(Model.SelectedObjectIds.Contains(item.Id) ? "checked" : null) />
                                <span>@item.Title - @item.ObjectType - @item.BorrowerName</span>
                            </label>
                        }
                    </div>
                }
                else
                {
                    <p>Inga färdiga objekt hittades.</p>
                }
            </div>

            <div class="form-group">
                <label asp-for="Summary">Sammanfattning</label>
                <textarea asp-for="Summary" class="form-input form-textarea"></textarea>
                <span asp-validation-for="Summary" class="validation-text"></span>
            </div>

            <div class="button-row">
                <button type="submit" class="btn-primary">Spara rapport</button>
                <a asp-controller="AdvancedAdmin" asp-action="Index" class="btn-secondary text-decoration-none">Tillbaka</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}