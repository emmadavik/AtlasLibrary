@model List<AtlasLibrary.Controllers.AdvancedAdminController.ReportDto>

@{
    ViewData["Title"] = "Rapporter";
}

<div class="page-wrapper">
    <div class="top-navigation" style="margin-bottom: 22px;">
        <a asp-controller="AdvancedAdmin" asp-action="Index" class="top-action-btn profile-btn text-decoration-none">
            ← Tillbaka till adminpanelen
        </a>
    </div>

    <div class="table-card">
        <div class="page-header-row">
            <div>
                <p class="eyebrow">Rapporter</p>
                <h1>Alla rapporter</h1>
                <p class="sub-text">Här visas alla skapade rapporter i systemet.</p>
            </div>

            <a asp-controller="AdvancedAdmin" asp-action="CreateReport" class="btn-primary text-decoration-none">
                Skapa ny rapport
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="warning-box">@TempData["Success"]</div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="warning-box">@TempData["Error"]</div>
        }

        @if (ViewBag.Error != null)
        {
            <div class="warning-box">
                @ViewBag.Error
            </div>
        }

        @if (Model != null && Model.Any())
        {
            <div class="table-responsive">
                <table class="simple-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Titel</th>
                            <th>Sammanfattning</th>
                            <th>Skapad</th>
                            <th>Valda objekt</th>
                            <th>Åtgärder</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var report in Model)
                        {
                            <tr>
                                <td>@report.Id</td>
                                <td>@report.Title</td>
                                <td>@report.Summary</td>
                                <td>@report.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                <td>@report.SelectedObjectIds</td>
                                <td class="action-cell">
                                    <a asp-controller="AdvancedAdmin" asp-action="EditReport" asp-route-id="@report.Id" class="text-link">
                                        Redigera
                                    </a>

                                    <form asp-controller="AdvancedAdmin" asp-action="DeleteReport" asp-route-id="@report.Id" method="post" style="display:inline;">
                                        <button type="submit" class="text-link delete-link" onclick="return confirm('Är du säker på att du vill ta bort rapporten?')">
                                            Ta bort
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="empty-card">
                <p>Det finns inga rapporter ännu.</p>
            </div>
        }
    </div>
</div>