@model AtlasLibrary.Models.CreateLoanViewModel

<div class="container mt-5">

    <h1 class="mb-4">Bekräfta lån</h1>

    <div class="card p-4 shadow-sm">

        <!-- LISTA MED ITEMS -->
        <h4 class="mb-3">Dina valda items</h4>

        <table class="table">
            <thead>
                <tr>
                    <th>Item</th>
                    <th>Antal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.CartItems)
                {
                    <tr>
                        
                        <td>
                            <div style="display:flex; align-items:center; gap:10px;">
                                <img src="@item.ImageUrl" style="width:50px; height:70px; object-fit:cover;" />
                                <span>@item.Title</span>
                            </div>
                        </td>
                        <td>@item.Quantity</td>
                    </tr>
                }
            </tbody>
        </table>

        <!-- FORM -->
        <form asp-action="Create" method="post">

            <input type="hidden" asp-for="UserId" />

            <!-- ÅTERLÄMNINGS DATUM -->
            <div class="mb-3">
                <label class="form-label">Återlämningsdatum</label>
                <input asp-for="DueDate" type="date" class="form-control" />
            </div>

            <!-- KNAPP -->
            <button type="submit" class="btn btn-success w-100">
                Bekräfta lån
            </button>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}