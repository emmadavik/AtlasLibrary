@{
    ViewData["Title"] = "Hem";
}

<div class="home-page">
    <section class="hero-section">
        <div class="hero-content">
            <h1>Låna böcker och utrustning</h1>
            <p>
                Kolla bland alla våra alternativ av böcker och utrustning.
                Hitta det du behöver och hantera dina lån enkelt.
            </p>
            <a asp-controller="Items" asp-action="Index" class="primary-btn">Klicka här</a>
        </div>
    </section>

    <section class="news-section">
        <div class="news-content">
            <h2>Våra nyheter på böcker</h2>
            <p>
                Ta del av nya titlar, uppdateringar och information om
                tillgängliga resurser i biblioteket.
            </p>
            <a asp-controller="Home" asp-action="Privacy" class="primary-btn">Klicka här</a>
        </div>
    </section>
</div>
