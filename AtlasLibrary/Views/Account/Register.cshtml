@{
    ViewData["Title"] = "Skapa konto";
}

<div class="login-page">
    <div class="login-card">
        <div class="login-content">
            <h1>Skapa konto</h1>
            <p>Fyll i uppgifterna för att skapa ett nytt konto.</p>

            @if (ViewBag.Error != null)
            {
                <div class="login-error">
                    @ViewBag.Error
                </div>
            }

            <form method="post" asp-controller="Account" asp-action="Register" class="login-form">
                <div class="form-group-custom">
                    <label for="namn">Namn</label>
                    <input type="text" id="namn" name="namn" class="login-input" required />
                </div>

                <div class="form-group-custom">
                    <label for="epost">E-post</label>
                    <input type="text" id="epost" name="epost" class="login-input" required />
                </div>

                <div class="form-group-custom">
                    <label for="losenord">Lösenord</label>
                    <input type="password" id="losenord" name="losenord" class="login-input" required />
                </div>

                <button type="submit" class="login-submit-btn">Skapa konto</button>
            </form>

            <div class="mt-3 text-center">
                <a asp-controller="Account" asp-action="Login">Tillbaka till inloggning</a>
            </div>
        </div>
    </div>
</div>