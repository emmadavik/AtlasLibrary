@{
    ViewData["Title"] = "Byt lösenord";
}

<div class="login-page">
    <div class="login-card">
        <div class="login-content">
            <h1>Byt lösenord</h1>
            <p>Här kan du uppdatera ditt lösenord.</p>

            <form method="post" asp-controller="Profile" asp-action="ChangePassword" class="login-form">

                <div class="form-group-custom">
                    <label for="CurrentPassword">Nuvarande lösenord</label>
                    <input type="password" id="CurrentPassword" name="CurrentPassword" class="login-input" required />
                </div>

                <div class="form-group-custom">
                    <label for="NewPassword">Nytt lösenord</label>
                    <input type="password" id="NewPassword" name="NewPassword" class="login-input" required />
                </div>

                <div class="profile-actions">
                    <button type="submit" class="login-submit-btn">Spara nytt lösenord</button>

                    <a asp-controller="Profile" asp-action="Index" class="profile-btn text-decoration-none">
                        Tillbaka till profil
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>