@model AtlasLibrary.Controllers.ProfileController.ProfilePageViewModel

@{
    ViewData["Title"] = "Profil";
}

<div class="login-page">
    <div class="login-card">
        <div class="login-content">
            <h1>Min profil</h1>
            <p>Här kan du se och uppdatera dina användaruppgifter.</p>

            @if (ViewBag.Error != null)
            {
                <div class="login-error">
                    @ViewBag.Error
                </div>
            }

            @if (ViewBag.Success != null)
            {
                <div class="login-success">
                    @ViewBag.Success
                </div>
            }

            <form method="post" asp-controller="Profile" asp-action="Index" class="login-form">
                <input type="hidden" asp-for="Profile.Id" />

                <div class="form-group-custom">
                    <label for="Profile_Namn">Användarnamn</label>
                    <input type="text" id="Profile_Namn" name="Profile.Namn" class="login-input" value="@Model.Profile.Namn" required />
                </div>

                <div class="form-group-custom">
                    <label for="Profile_Epost">E-post</label>
                    <input type="text" id="Profile_Epost" name="Profile.Epost" class="login-input" value="@Model.Profile.Epost" required />
                </div>

                <div class="profile-actions">
                    <button type="submit" class="login-submit-btn">Spara ändringar</button>
                    <a asp-controller="Profile" asp-action="ChangePassword" class="profile-btn text-decoration-none">Ändra lösenord</a>

                    @if (Model.Profile.IsAdmin)
                    {
                        <a asp-controller="Admin" asp-action="Index" class="profile-btn text-decoration-none">Hantera användare</a>
                    }
                </div>
            </form>

            <hr style="margin: 30px 0;" />

            <h2>Mina lån</h2>

            @if (Model.Loans != null && Model.Loans.Any())
            {
                <div style="overflow-x: auto;">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Lån-ID</th>
                                <th>Item-ID</th>
                                <th>Antal</th>
                                <th>Lånedatum</th>
                                <th>Förfallodatum</th>
                                <th>Återlämnad</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var loan in Model.Loans)
                            {
                                <tr>
                                    <td>@loan.Id</td>
                                    <td>@loan.ItemId</td>
                                    <td>@loan.Quantity</td>
                                    <td>@loan.LoanDate.ToString("yyyy-MM-dd")</td>
                                    <td>@loan.DueDate.ToString("yyyy-MM-dd")</td>
                                    <td>@(loan.ReturnedDate.HasValue ? loan.ReturnedDate.Value.ToString("yyyy-MM-dd") : "-")</td>
                                    <td>@loan.Status</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p>Du har inga lån ännu.</p>
            }
        </div>
    </div>
</div>