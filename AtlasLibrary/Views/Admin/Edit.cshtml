@model AtlasLibrary.Controllers.AdminController.AdminUserEditViewModel

@{
    ViewData["Title"] = "Redigera användare";
}

<div class="login-page">
    <div class="login-card">
        <div class="login-content">
            <h1>Redigera användare</h1>
            <p>Här kan administratören uppdatera användarens uppgifter.</p>

            @if (ViewBag.Error != null)
            {
                <div class="login-error">
                    @ViewBag.Error
                </div>
            }

            <form method="post" asp-controller="Admin" asp-action="Edit" class="login-form">
                <input type="hidden" name="Id" value="@Model.Id" />

                <div class="form-group-custom">
                    <label for="Namn">Användarnamn</label>
                    <input type="text" id="Namn" name="Namn" class="login-input" value="@Model.Namn" required />
                </div>

                <div class="form-group-custom">
                    <label for="Epost">E-post</label>
                    <input type="text" id="Epost" name="Epost" class="login-input" value="@Model.Epost" required />
                </div>

                <div class="form-group-custom">
                    <label for="Losenord">Nytt lösenord (lämna tomt om du inte vill ändra)</label>
                    <input type="password" id="Losenord" name="Losenord" class="login-input" />
                </div>

                <div class="form-group-custom">
                    <label for="Roll">Roll</label>
                    <select id="Roll" name="Roll" class="login-input" required>
                        @if (Model.Roll == "Admin")
                        {
                            <option value="Admin" selected>Admin</option>
                            <option value="User">User</option>
                        }
                        else
                        {
                            <option value="User" selected>User</option>
                            <option value="Admin">Admin</option>
                        }
                    </select>
                </div>

                <div class="profile-actions">
                    <button type="submit" class="login-submit-btn">Spara ändringar</button>

                    <a asp-controller="Admin" asp-action="Index" class="profile-btn text-decoration-none">
                        Tillbaka
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>