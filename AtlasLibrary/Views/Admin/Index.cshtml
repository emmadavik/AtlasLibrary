@model List<AtlasLibrary.Controllers.AdminController.AdminUserViewModel>

@{
    ViewData["Title"] = "Hantera användare";
}
<link rel="stylesheet" href="~/css/AdminPanel.css" asp-append-version="true" />
<div class="admin-page">
    <div class="admin-header">
        <h1>Hantera användare</h1>
        <p>Här kan administratören se alla användare i systemet.</p>
    </div>

    <div class="admin-card">
        <div class="admin-actions">
            <a asp-controller="Admin" asp-action="Create" class="login-submit-btn text-decoration-none">
                Lägg till användare
            </a>
        </div>

        <div class="admin-table-wrapper">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Namn</th>
                        <th>E-post</th>
                        <th>Roll</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.Id</td>
                            <td>@user.Namn</td>
                            <td>@user.Epost</td>
                            <td>
                                <span class="role-badge">@user.Roll</span>
                            </td>
                            <td>
                                <div class="admin-row-actions">
                                    <a asp-controller="Admin"
                                           asp-action="Edit"
                                           asp-route-id="@user.Id"
                                           class="profile-btn text-decoration-none">
                                        Redigera
                                    </a>

                                    <form asp-controller="Admin"
                                          asp-action="Delete"
                                          asp-route-id="@user.Id"
                                          method="post"
                                          class="delete-form">
                                        <button type="submit"
                                                class="admin-delete-btn"
                                                onclick="return confirm('Är du säker på att du vill ta bort användaren?');">
                                            Ta bort
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>