@model LibraryAdminPanel.Models.Reminder
@{
    ViewData["Title"] = "Ta bort reminder";
}

<div class="form-card">
    <h1>Ta bort reminder</h1>
    <p>Är du säker på att du vill ta bort remindern för <strong>@Model.ObjectTitle</strong>?</p>

    <div class="info-list">
        <p><strong>Låntagare:</strong> @Model.BorrowerName</p>
        <p><strong>E-post:</strong> @Model.BorrowerEmail</p>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="button-row">
            <button type="submit" class="btn-danger">Ta bort</button>
            <a asp-action="Index" class="btn-secondary">Avbryt</a>
        </div>
    </form>
</div>
