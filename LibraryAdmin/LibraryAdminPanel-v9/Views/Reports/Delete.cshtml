@model LibraryAdminPanel.Models.Report
@{
    ViewData["Title"] = "Ta bort rapport";
}

<div class="form-card">
    <h1>Ta bort rapport</h1>
    <p>Är du säker på att du vill ta bort <strong>@Model.Title</strong>?</p>

    <div class="info-list">
        <p><strong>Antal objekt:</strong> @Model.ObjectCount</p>
        <p><strong>Valda objekt:</strong> @string.Join(", ", Model.SelectedObjects.Select(x => x.Title))</p>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="button-row">
            <button type="submit" class="btn-danger">Ta bort</button>
            <a asp-action="Index" class="btn-secondary">Avbryt</a>
        </div>
    </form>
</div>
