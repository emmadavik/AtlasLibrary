@inject IConfiguration Configuration
<!DOCTYPE html>
<html lang="sv">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LibraryAdminPanel</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<header class="site-header">
    <div class="header-left">Logga Admin</div>

    <nav class="top-nav">
        <a asp-controller="Admin" asp-action="Index">Dashboard</a>
        <a href="@(Configuration["ExternalLinks:ManageObjectsUrl"] ?? "#")">Hantera Objekt</a>
        <a href="@(Configuration["ExternalLinks:ManageReservationsUrl"] ?? "#")">Hantera reservation</a>
    </nav>

    <div class="header-right">
        <a href="/Profile" class="top-action-btn profile-btn">Profile</a>
        <a href="/Login" class="top-action-btn sign-in-btn">Sign In</a>
    </div>
</header>

<main class="page-wrapper">
    @RenderBody()
</main>
</body>
</html>