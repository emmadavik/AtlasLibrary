@{
    ViewData["Title"] = "Dashboard";
}

<section class="hero-card">
    <div>
        <p class="eyebrow">Admin</p>
        <h1>Dashboard för rapporter och reminders</h1>
    </div>
</section>

<section class="stats-grid">
    <div class="small-card">
        <span class="stat-number">@ViewBag.ReportCount</span>
        <span class="stat-label">Skapade rapporter</span>
    </div>
    <div class="small-card">
        <span class="stat-number">@ViewBag.ReminderCount</span>
        <span class="stat-label">Skapade reminders</span>
    </div>
</section>

<section class="dashboard-grid">
    <div class="admin-card">
        <h2>Rapporter</h2>
        <p>Skapa en rapport från ett eller flera färdiga objekt.</p>
        <div class="button-row">
            <a class="btn-primary" asp-controller="Reports" asp-action="Create">Skapa ny rapport</a>
            <a class="btn-secondary" asp-controller="Reports" asp-action="Index">Visa rapporter</a>
        </div>
    </div>

    <div class="admin-card">
        <h2>Reminders</h2>
        <p>Skapa reminders baserat på färdiga objekt.</p>
        <div class="button-row">
            <a class="btn-primary" asp-controller="Reminders" asp-action="Create">Skapa ny reminder</a>
            <a class="btn-secondary" asp-controller="Reminders" asp-action="Index">Visa reminders</a>
        </div>
    </div>
</section>
