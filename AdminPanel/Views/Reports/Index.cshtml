@model List<LibraryAdminPanel.Models.Report>

@{
    ViewData["Title"] = "Rapporter";
}

<div class="form-card">
    <h1>Rapporter</h1>

    @if (!Model.Any())
    {
        <p>Inga rapporter skapade ännu.</p>
    }
    else
    {
        <table class="table">
            <thead>
            <tr>
                <th>Titel</th>
                <th>Sammanfattning</th>
                <th>Valda objekt</th>
                <th>Skapad</th>
                <th>Åtgärder</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var report in Model)
            {
                var selectedCount = 0;

                if (!string.IsNullOrWhiteSpace(report.SelectedObjectIds))
                {
                    selectedCount = report.SelectedObjectIds
                        .Split(',', StringSplitOptions.RemoveEmptyEntries)
                        .Length;
                }

                <tr>
                    <td>@report.Title</td>
                    <td>@report.Summary</td>
                    <td>@selectedCount</td>
                    <td>@report.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                    <td class="action-cell">
                        <a class="text-link" asp-action="Edit" asp-route-id="@report.Id">Ändra</a>
                        <a class="text-link delete-link" asp-action="Delete" asp-route-id="@report.Id">Ta bort</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }

    <div class="button-row" style="margin-top: 20px;">
        <a asp-action="Create" class="btn-primary">Skapa ny rapport</a>
    </div>
</div>